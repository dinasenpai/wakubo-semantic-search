{{ 'search-widget.css' | asset_url | stylesheet_tag }}

{%- comment -%} Capture theme colors and fonts {%- endcomment -%}
{%- liquid
  assign primary_color = settings.colors_accent_1 | default: '#667eea'
  assign text_color = settings.colors_text | default: '#2d3748'
  assign bg_color = settings.colors_background_1 | default: '#ffffff'
  assign button_text = settings.colors_solid_button_labels | default: '#ffffff'

  assign font_heading = settings.type_header_font.family | default: 'sans-serif'
  assign font_body = settings.type_body_font.family | default: 'sans-serif'
-%}

<div
  id="semantic-search-float"
  class="semantic-search-minimized"
  data-theme-primary="{{ primary_color }}"
  data-theme-text="{{ text_color }}"
  data-theme-bg="{{ bg_color }}"
  data-theme-button-text="{{ button_text }}"
  data-font-heading="{{ font_heading }}"
  data-font-body="{{ font_body }}"
  style="--theme-primary: {{ primary_color }}; --theme-text: {{ text_color }}; --theme-bg: {{ bg_color }}; --theme-button-text: {{ button_text }}; --font-heading: {{ font_heading }}; --font-body: {{ font_body }};"
>
  <div id="search-panel" class="search-panel" role="dialog" aria-label="{{ block.settings.heading }}">
    <div class="search-shell">
      <input
        type="text"
        id="search-input"
        placeholder="{{ block.settings.search_placeholder }}"
        aria-label="Search products"
      />
      <div class="search-actions">
        <button id="camera-btn" class="icon-btn icon-camera-btn" type="button" aria-label="Image search">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9.2 4a1 1 0 0 0-.8.4L7.5 6H5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3V9a3 3 0 0 0-3-3h-2.5l-.9-1.6a1 1 0 0 0-.8-.4H9.2ZM12 9a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"/>
          </svg>
        </button>
        <button
          id="search-btn"
          class="icon-btn icon-search-btn"
          type="button"
          data-api="{{ block.settings.api_endpoint }}"
          aria-label="Search"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M15.5 14h-.8l-.3-.3a6 6 0 1 0-.9.9l.3.3v.8L19 21l2-2-5.5-5ZM6 10a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z"/>
          </svg>
        </button>
      </div>
    </div>

    <input
      type="file"
      id="camera-input"
      accept="image/*"
      capture="environment"
      style="display:none;"
      aria-label="Upload image for search"
    />

    <div id="search-results" class="search-results" aria-live="polite"></div>
  </div>
</div>

{{ 'search-widget.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Semantic Search",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Widget Content" },
    { "type": "text", "id": "heading", "label": "Widget Title", "default": "Semantic Search" },
    { "type": "text", "id": "search_placeholder", "label": "Search Placeholder", "default": "Search products..." },
    { "type": "text", "id": "api_endpoint", "label": "API Endpoint", "default": "https://wakubo-semantic-search-production.up.railway.app" },

    { "type": "header", "content": "Appearance Override" },
    { "type": "paragraph", "content": "Leave blank to auto-detect from theme. Override only if needed." },
    { "type": "color", "id": "custom_primary_color", "label": "Custom Primary Color (optional)" },
    { "type": "color", "id": "custom_text_color", "label": "Custom Text Color (optional)" },
    { "type": "color", "id": "custom_bg_color", "label": "Custom Background Color (optional)" }
  ]
}
{% endschema %}
